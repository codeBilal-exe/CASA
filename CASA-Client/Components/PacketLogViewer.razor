@namespace CASA_Client.Components
@using CASA_Client.Models
@using CASA_Client.Services
@implements IDisposable
@inject PacketLogService LogService

<div class="log-panel terminal-log">
    <div class="log-header">
        <span class="log-title">LIVE PACKET TRACER</span>
        <span class="log-hint">UDP = DNS | TCP = HTTP | ERR = Error</span>
        <button class="btn-clr" @onclick="LogService.Clear">CLR</button>
    </div>

    <div class="log-body log-body-h" id="log-scroll">
        <div class="log-header-row">
            <span class="log-bar" style="visibility: hidden;"></span>
            <span class="log-ts">TIMESTAMP</span>
            <span class="log-proto">PROTO</span>
            <span class="log-action">ACTION</span>
            <span class="log-elapsed">TIME</span>
            <span class="log-msg">MESSAGE</span>
        </div>
        @foreach (var log in LogService.Logs)
        {
            <div class="log-row @log.Protocol.ToLower()">
                <span class="log-bar"></span>
                <span class="log-ts">[@log.Timestamp.ToString("HH:mm:ss.fff")]</span>
                <span class="log-proto">@log.Protocol.PadRight(7)</span>
                <span class="log-action">@log.Action.PadRight(10)</span>
                @if (log.ElapsedMs.HasValue)
                {
                    <span class="log-elapsed">@($"{log.ElapsedMs.Value:F1}ms")</span>
                }
                else
                {
                    <span class="log-elapsed"></span>
                }
                <span class="log-msg">@log.Message</span>
            </div>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        LogService.OnChanged += Refresh;
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LogService.OnChanged -= Refresh;
    }
}
