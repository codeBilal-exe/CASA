@page "/"
@namespace CASA_Client.Components.Pages
@using CASA_Client.Services
@using CASA_Client.Models
@using System.Diagnostics
@using System.IO
@inject NetworkingService Network
@inject PacketLogService LogService
@inject CacheService Cache

<PageTitle>CASA - Browser</PageTitle>

<div class="browser-page">
    <section class="browser-toolbar">
        <div class="address-bar-wrap">
            <span class="ab-label">http://</span>
            <input class="address-input"
                   @bind="_domain"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   placeholder="apple.com"
                   spellcheck="false" />

            <div class="browser-actions">
                <button class="btn btn-go @(_loading ? "btn-loading" : "")"
                        @onclick="Navigate"
                        disabled="@_loading">
                    @(_loading ? "Loading" : "Go")
                </button>

                <button class="btn btn-ghost @(_sourceOpen ? "active" : "")"
                        @onclick="ToggleSource"
                        title="Toggle HTML source">
                    Source
                </button>

                <button class="btn btn-tracer @(_tracerOpen ? "active" : "")"
                        @onclick="ToggleTracer"
                        title="Toggle Live Packet Tracer">
                    Live Tracer
                </button>
            </div>
        </div>

        <div class="status-strip">
            <span class="status-icon @_statusClass">@_statusIcon</span>
            <span class="status-text">@_statusText</span>
            @if (_loading)
            {
                <span class="status-loader"></span>
            }
        </div>
    </section>

    @if (_servedFromCache && _lastCacheEntry is not null)
    {
        <div class="cache-hit-badge">
            <span class="cache-hit-icon">CACHE</span>
            <span class="cache-hit-text">Served from Cache</span>
            <span class="cache-hit-meta">
                Cached @_lastCacheEntry.CachedAt.ToString("HH:mm:ss") |
                Hit #@_lastCacheEntry.HitCount |
                TTL @((int)_lastCacheEntry.TtlRemaining.TotalSeconds)s remaining
            </span>
            <a href="/cache" class="cache-hit-link">View Cache</a>
        </div>
    }
    else if (!string.IsNullOrEmpty(_html) && !_servedFromCache)
    {
        <div class="cache-stored-badge">
            <span>💾 Response cached</span>
            @if (!string.IsNullOrEmpty(_lbBackendPort))
            {
                <span class="lb-inline-badge">
                    ✦ @_lbAlgorithm → backend port
                    <strong>:@_lbBackendPort</strong>
                </span>
            }
            <a href="/cache" class="cache-hit-link">
                View Cache
            </a>
        </div>
    }

    <div class="browser-stage @(_tracerOpen ? "with-tracer" : "")">
        <div class="viewport-wrap">
            <div class="viewport @(_sourceOpen ? "shrunk" : "")">
                <div class="viewport-frame">
                    @if (!string.IsNullOrEmpty(_html))
                    {
                        <iframe class="render-frame"
                                srcdoc="@_html"
                                sandbox="allow-scripts allow-same-origin"
                                title="Rendered page"></iframe>
                    }
                    else
                    {
                        <div class="viewport-empty">
                            <div class="empty-icon-wrap">
                                <svg viewBox="0 0 24 24" style="width:28px;height:28px;stroke:var(--text-muted);fill:none;stroke-width:1.3;stroke-linecap:round;stroke-linejoin:round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                            </div>
                            <div class="empty-headline">Web Viewport</div>
                            <div class="empty-text">Enter a domain above and press Go</div>
                            <div class="empty-hint">Try: apple.com, google.com, github.com</div>
                        </div>
                    }
                </div>
            </div>

            @if (_sourceOpen)
            {
                <div class="source-panel">
                    <div class="source-header">
                        <span>INDEX.HTML SOURCE</span>
                        <span class="source-bytes">@_html.Length bytes</span>
                    </div>
                    <pre class="source-body"><code>@_html</code></pre>
                </div>
            }
        </div>

        @if (_tracerOpen)
        {
            <div class="tracer-drawer">
                <PacketLogViewer />
            </div>
        }
    </div>
</div>

@code {
    private string _domain = "apple.com";
    private string _html = string.Empty;
    private bool _loading;
    private bool _sourceOpen;
    private bool _tracerOpen;
    private bool _servedFromCache = false;
    private CacheEntry? _lastCacheEntry = null;
    private string _statusText = "Ready - enter a domain and press Go";
    private string _statusIcon = "*";
    private string _statusClass = "idle";
    private string _lbBackendPort = string.Empty;
    private string _lbAlgorithm = string.Empty;

    private void ToggleSource() => _sourceOpen = !_sourceOpen;
    private void ToggleTracer() => _tracerOpen = !_tracerOpen;

    private (string backendPort, string algorithm) ReadLbInfo()
    {
        try
        {
            string basePath = Path.GetFullPath(
                Path.Combine(
                    AppDomain.CurrentDomain.BaseDirectory,
                    "../../../.."));

            string statsPath = Path.Combine(
                basePath, "Servers", "Load_Balancer",
                "lb_stats.json");

            string configPath = Path.Combine(
                basePath, "Servers", "Load_Balancer",
                "lb_config.json");

            string backendPort = string.Empty;
            string algorithm = "Round Robin";

            if (File.Exists(statsPath))
            {
                string json = File.ReadAllText(statsPath);
                var m = System.Text.RegularExpressions.Regex.Match(
                    json,
                    "\"last_route\"\\s*:\\s*\"[^\"]*->\\s*(\\d+)\"");
                if (m.Success)
                    backendPort = m.Groups[1].Value.Trim();
            }

            if (File.Exists(configPath))
            {
                string json = File.ReadAllText(configPath);
                var m = System.Text.RegularExpressions.Regex.Match(
                    json,
                    "\"Algorithm\"\\s*:\\s*\"([^\"]+)\"");
                if (m.Success)
                    algorithm = m.Groups[1].Value.Trim();
            }

            return (backendPort, algorithm);
        }
        catch
        {
            return (string.Empty, "Round Robin");
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Navigate();
        }
    }

    private async Task Navigate()
    {
        string domain = _domain.Trim()
            .ToLower()
            .Replace("http://", "")
            .Replace("https://", "")
            .TrimEnd('/');

        if (string.IsNullOrEmpty(domain)) return;
        var _sw = System.Diagnostics.Stopwatch.StartNew();

        _loading = true;
        _servedFromCache = false;
        _lastCacheEntry = null;
        _lbBackendPort = string.Empty;
        _lbAlgorithm = string.Empty;
        _statusText = $"Resolving {domain} ...";
        _statusIcon = ">";
        _statusClass = "loading";
        StateHasChanged();

        LogService.Add("BROWSER", "Navigate", $"User requested: {domain}");

        var sw = Stopwatch.StartNew();

        // Cache check
        if (Cache.TryGet(domain, out var cached) && cached is not null)
        {
            _sw.Stop();
            double msCache = _sw.Elapsed.TotalMilliseconds;
            string cachedPortInfo = cached.Port != 8080
                ? $"originally backend :{cached.Port} — "
                : string.Empty;

            LogService.Add("CACHE", "HIT",
                $"Served '{domain}' from cache — {cachedPortInfo}" +
                $"hit #{cached.HitCount} [{cached.SizeBytes} bytes] " +
                $"— {msCache:F2} ms (Load Balancer bypassed)",
                msCache);
            _html = cached.HtmlContent;
            _servedFromCache = true;
            _lastCacheEntry = cached;
            _statusText = $"CACHE HIT {domain} [{cached.SizeBytes} bytes] (hit #{cached.HitCount}) {msCache:F2} ms";
            _statusIcon = "*";
            _statusClass = "ok";
            _loading = false;
            StateHasChanged();
            return;
        }
        // End cache check

        try
        {
            LogService.Add("UDP", "Query ->", $"DNS lookup for [{domain}] -> 127.0.0.1:5053");
            var dnsTimer = Stopwatch.StartNew();
            var (ip, port) = await Network.ResolveDnsAsync(domain);
            dnsTimer.Stop();

            if (ip == "NOT_FOUND")
            {
                LogService.Add("UDP", "NXDOMAIN", $"No DNS record for [{domain}]", dnsTimer.Elapsed.TotalMilliseconds);
                ShowError("NXDOMAIN", $"No DNS record for '{domain}'.");
                return;
            }

            LogService.Add("UDP", "<- Reply", $"Resolved {domain} -> {ip}:{port}", dnsTimer.Elapsed.TotalMilliseconds);
            _statusText = $"Connecting {ip}:{port} ...";
            StateHasChanged();

            LogService.Add("TCP", "SYN ->", $"Opening TCP connection to {ip}:{port}");
            var httpTimer = Stopwatch.StartNew();
            string html = await Network.FetchPageAsync(ip, port, domain);
            httpTimer.Stop();
            LogService.Add("TCP", "<- ACK", $"HTML received ({html.Length} bytes)", httpTimer.Elapsed.TotalMilliseconds);

            // Read which backend the Load Balancer actually chose
            var (lbPort, lbAlgo) = ReadLbInfo();
            _lbBackendPort = lbPort;
            _lbAlgorithm = lbAlgo;

            if (!string.IsNullOrEmpty(lbPort))
            {
                LogService.Add("LB", "Route",
                    $"[{lbAlgo}] {domain} — LB entry :8080 " +
                    $"→ backend :{lbPort}");
            }

            sw.Stop();
            // Cache store
            int backendPortNum = int.TryParse(
                _lbBackendPort, out int p) ? p : port;
            Cache.Set(domain, ip, backendPortNum, html);
            _sw.Stop();
            double msTotal = _sw.Elapsed.TotalMilliseconds;
            string portDisplay = string.IsNullOrEmpty(_lbBackendPort)
                ? $"{ip}:{port}"
                : $"{ip}:8080 → backend :{_lbBackendPort}";

            LogService.Add("CACHE", "STORE",
                $"Cached '{domain}' [{portDisplay}] [{html.Length} bytes] " +
                $"TTL={Cache.DefaultTtlMinutes}min " +
                $"— {msTotal:F2} ms (full network round-trip)",
                msTotal);
            // End cache store

            _html = html;
            string lbInfo = string.IsNullOrEmpty(_lbBackendPort)
                ? string.Empty
                : $"  via :{_lbBackendPort} [{_lbAlgorithm}]";

            _statusText = $"OK  {domain}  [{html.Length} bytes]" +
                          $"  ({msTotal:F2} ms){lbInfo}";
            _statusIcon = "+";
            _statusClass = "ok";
        }
        catch (Exception ex)
        {
            string msg = ex.Message switch
            {
                "DNS_OFFLINE"     => "DNS Server is Offline - start it in the SERVERS tab",
                "DNS_TIMEOUT"     => "DNS Request Timed Out",
                "SERVER_OFFLINE"  => $"'{domain}' server or Load Balancer is Offline. Go to SERVERS tab and ensure both the website server AND Load Balancer are running.",
                "SERVER_TIMEOUT"  => "Website Not Responding",
                _                 => $"Connection Error: {ex.Message}"
            };

            LogService.Add("ERROR", ex.Message, msg);
            ShowError(ex.Message, msg);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ShowError(string code, string message)
    {
        _statusText = $"ERROR  {message}";
        _statusIcon = "!";
        _statusClass = "error";

        _html = @"<!DOCTYPE html>
<html>
<head>
<meta charset='utf-8'>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#fff;color:#1a1a1a;font-family:Consolas,monospace;display:flex;align-items:center;justify-content:center;min-height:100vh}
.wrap{border:1px solid #B8504066;padding:48px 64px;text-align:center;max-width:560px;position:relative;overflow:hidden;border-radius:12px}
.wrap::before{content:'';position:absolute;left:0;top:0;width:3px;height:100%;background:linear-gradient(to bottom,#B85040,transparent)}
h1{font-size:1.6rem;color:#B85040;letter-spacing:3px;margin-bottom:12px}
.code{font-size:.8rem;color:#dc2626;margin-bottom:20px}
p{color:#334155;font-size:.85rem;line-height:1.8}
strong{color:#111}
hr{border:none;border-top:1px solid #e2e8f0;margin:18px 0}
.footer{font-size:.65rem;color:#94a3b8;letter-spacing:2px}
</style>
</head>
<body>
<div class='wrap'>
  <h1>" + code + @"</h1>
  <div class='code'>" + message + @"</div>
  <p>Ensure the required server is <strong>ONLINE</strong> before navigating.<br>
     Open the <em>SERVERS</em> tab to start it.</p>
  <hr>
  <div class='footer'>CASA | CLIENT AND SERVER ARCHITECTURE</div>
</div>
</body>
</html>";
    }
}
