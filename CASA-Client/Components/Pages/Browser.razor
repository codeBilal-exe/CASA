@page "/"
@namespace CASA_Client.Components.Pages
@using CASA_Client.Services
@using CASA_Client.Models
@inject NetworkingService Network
@inject PacketLogService LogService

<PageTitle>CASA - Browser</PageTitle>

<div class="browser-page">
    <section class="browser-toolbar">
        <div class="address-bar-wrap">
            <span class="ab-label">http://</span>
            <input class="address-input"
                   @bind="_domain"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   placeholder="apple.com"
                   spellcheck="false" />

            <div class="browser-actions">
                <button class="btn btn-go @(_loading ? "btn-loading" : "")"
                        @onclick="Navigate"
                        disabled="@_loading">
                    @(_loading ? "Loading" : "Go")
                </button>

                <button class="btn btn-ghost @(_sourceOpen ? "active" : "")"
                        @onclick="ToggleSource"
                        title="Toggle HTML source">
                    Source
                </button>

                <button class="btn btn-tracer @(_tracerOpen ? "active" : "")"
                        @onclick="ToggleTracer"
                        title="Toggle Live Packet Tracer">
                    Live Tracer
                </button>
            </div>
        </div>

        <div class="status-strip">
            <span class="status-icon @_statusClass">@_statusIcon</span>
            <span class="status-text">@_statusText</span>
            @if (_loading)
            {
                <span class="status-loader"></span>
            }
        </div>
    </section>

    <div class="browser-stage @(_tracerOpen ? "with-tracer" : "")">
        <div class="viewport-wrap">
            <div class="viewport @(_sourceOpen ? "shrunk" : "")">
                <div class="viewport-frame">
                    @if (!string.IsNullOrEmpty(_html))
                    {
                        <iframe class="render-frame"
                                srcdoc="@_html"
                                sandbox="allow-scripts allow-same-origin"
                                title="Rendered page"></iframe>
                    }
                    else
                    {
                        <div class="viewport-empty">
                            <div class="empty-icon">Web Viewport</div>
                            <div class="empty-text">Enter a domain and press Go</div>
                            <div class="empty-hint">Try: apple.com | google.com | github.com</div>
                        </div>
                    }
                </div>
            </div>

            @if (_sourceOpen)
            {
                <div class="source-panel">
                    <div class="source-header">
                        <span>INDEX.HTML SOURCE</span>
                        <span class="source-bytes">@_html.Length bytes</span>
                    </div>
                    <pre class="source-body"><code>@_html</code></pre>
                </div>
            }
        </div>

        @if (_tracerOpen)
        {
            <div class="tracer-drawer">
                <PacketLogViewer />
            </div>
        }
    </div>
</div>

@code {
    private string _domain = "apple.com";
    private string _html = string.Empty;
    private bool _loading;
    private bool _sourceOpen;
    private bool _tracerOpen;
    private string _statusText = "Ready - enter a domain and press Go";
    private string _statusIcon = "*";
    private string _statusClass = "idle";

    private void ToggleSource() => _sourceOpen = !_sourceOpen;
    private void ToggleTracer() => _tracerOpen = !_tracerOpen;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Navigate();
        }
    }

    private async Task Navigate()
    {
        string domain = _domain.Trim()
            .ToLower()
            .Replace("http://", "")
            .Replace("https://", "")
            .TrimEnd('/');

        if (string.IsNullOrEmpty(domain))
        {
            return;
        }

        _loading = true;
        _statusText = $"Resolving {domain} ...";
        _statusIcon = ">";
        _statusClass = "loading";
        StateHasChanged();

        LogService.Add("BROWSER", "Navigate", $"User requested: {domain}");

        try
        {
            LogService.Add("UDP", "Query ->", $"DNS lookup for [{domain}] -> 127.0.0.1:5053");
            var (ip, port) = await Network.ResolveDnsAsync(domain);

            if (ip == "NOT_FOUND")
            {
                LogService.Add("UDP", "NXDOMAIN", $"No DNS record for [{domain}]");
                ShowError("NXDOMAIN", $"No DNS record for '{domain}'.");
                return;
            }

            LogService.Add("UDP", "<- Reply", $"Resolved {domain} -> {ip}:{port}");
            _statusText = $"Connecting {ip}:{port} ...";
            StateHasChanged();

            LogService.Add("TCP", "SYN ->", $"Opening TCP connection to {ip}:{port}");
            string html = await Network.FetchPageAsync(ip, port);
            LogService.Add("TCP", "<- ACK", $"HTML received ({html.Length} bytes)");

            _html = html;
            _statusText = $"OK  {domain}  [{html.Length} bytes]";
            _statusIcon = "+";
            _statusClass = "ok";
        }
        catch (Exception ex)
        {
            string msg = ex.Message switch
            {
                "DNS_OFFLINE" => "DNS Server is Offline - start it in the SERVERS tab",
                "DNS_TIMEOUT" => "DNS Request Timed Out",
                "SERVER_OFFLINE" => "Website Server is Offline - start it in the SERVERS tab",
                "SERVER_TIMEOUT" => "Website Not Responding",
                _ => $"Connection Error: {ex.Message}"
            };

            LogService.Add("ERROR", ex.Message, msg);
            ShowError(ex.Message, msg);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ShowError(string code, string message)
    {
        _statusText = $"ERROR  {message}";
        _statusIcon = "!";
        _statusClass = "error";

        _html = @"<!DOCTYPE html>
<html>
<head>
<meta charset='utf-8'>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{background:#ffffff;color:#1a1a1a;font-family:Consolas,monospace;display:flex;align-items:center;justify-content:center;min-height:100vh}
.wrap{border:1px solid #ff005588;padding:52px 72px;text-align:center;max-width:600px;background:#ffffff;position:relative;overflow:hidden}
.wrap::before{content:'';position:absolute;left:0;top:0;width:3px;height:100%;background:linear-gradient(to bottom,#ff0055,transparent)}
h1{font-size:1.8rem;color:#ff0055;letter-spacing:3px;margin-bottom:14px}
.code{font-size:.82rem;color:#dc2626;margin-bottom:24px}
p{color:#334155;font-size:.88rem;line-height:1.8}
strong{color:#111827}
em{color:#0f172a;font-style:normal}
hr{border:none;border-top:1px solid #e2e8f0;margin:20px 0}
.footer{font-size:.68rem;color:#64748b;letter-spacing:2px}
</style>
</head>
<body>
<div class='wrap'>
  <h1>" + code + @"</h1>
  <div class='code'>" + message + @"</div>
  <p>Ensure the required server is <strong>ONLINE</strong> before navigating.<br>
     Open the <em>SERVERS</em> tab to start it.</p>
  <hr>
  <div class='footer'>CASA | CLIENT AND SERVER ARCHITECTURE</div>
</div>
</body>
</html>";
    }
}
