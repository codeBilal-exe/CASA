@page "/servers"
@namespace CASA_Client.Components.Pages
@using CASA_Client.Services
@using CASA_Client.Models
@inject ServerControlService ServerControl
@inject PacketLogService LogService

<PageTitle>CASA - Servers</PageTitle>

<div class="servers-page">
    <div class="servers-header">
        <div class="sh-accent"></div>
        <div class="sh-text">
            <h1>Server Control Panel</h1>
            <p>Start or stop servers before browsing domains.</p>
        </div>
        <div class="servers-header-actions">
            <button class="btn btn-start-all"
                    @onclick="StartAll">
                ▶ Start All
            </button>
            <button class="btn btn-stop-all"
                    @onclick="StopAllServers">
                ■ Stop All
            </button>
            <button class="btn btn-tracer @(_tracerOpen ? "active" : "")"
                    @onclick="ToggleTracer">
                Live Tracer
            </button>
        </div>
    </div>

    <div class="servers-grid">
        @foreach (var server in ServerControl.Servers)
        {
            <ServerCard Server="server" OnLog="HandleLog" />
        }
    </div>

    @if (_tracerOpen)
    {
        <div class="servers-log-section">
            <PacketLogViewer />
        </div>
    }
</div>

@code {
    private bool _tracerOpen;

    private void ToggleTracer() => _tracerOpen = !_tracerOpen;

    private void StartAll()
    {
        foreach (var server in ServerControl.Servers)
        {
            if (!server.IsOnline)
            {
                ServerControl.Start(server);
                LogService.Add("SYSTEM", "START", $"{server.Name} -> ONLINE");
            }
        }
        StateHasChanged();
    }

    private void StopAllServers()
    {
        foreach (var server in ServerControl.Servers)
        {
            if (server.IsOnline)
            {
                ServerControl.Stop(server);
                LogService.Add("SYSTEM", "STOP", $"{server.Name} -> OFFLINE");
            }
        }
        StateHasChanged();
    }

    private void HandleLog(string raw)
    {
        var parts = raw.Split('|', 3);
        if (parts.Length == 3)
        {
            LogService.Add(parts[0], parts[1], parts[2]);
        }
    }
}
